# Optional: override default ~/.config/bittensor-wallet
BTW_CONFIG_DIR=~/.bittensor/js-wallet

# Chain RPC endpoint (wallet balance and future chain actions)
BTW_WS_URL=wss://entrypoint-finney.opentensor.ai:443
# CHAIN_ENDPOINT=wss://entrypoint-finney.opentensor.ai:443
# BTW_FINNEY_WS_URL=wss://entrypoint-finney.opentensor.ai:443
# BTW_TEST_WS_URL=wss://test.finney.opentensor.ai:443

# Optional default wallet for commands like `btw wallet balance`
# BTW_WALLET_NAME=alice
